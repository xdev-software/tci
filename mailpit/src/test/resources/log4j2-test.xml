<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Configuration>
<Configuration status="ERROR">

	<Properties>
		<Property name="consolePattern">%d{HH:mm:ss} %-5p [%t] [%-25.25c] %m %n</Property>
	</Properties>

	<Appenders>
		<Console name="stdout" target="SYSTEM_OUT">
			<PatternLayout pattern="${consolePattern}"/>
		</Console>
	</Appenders>

	<Loggers>
		<!-- *** Container: WARN = OFF, INFO = ALL *** -->
		<logger name="container.mailpit" level="WARN"/>

		<!-- Turn off start and stop for GetPort Container -->
		<logger name="tc.container.getport" level="WARN"/>
		<logger name="tc.alpine" level="WARN"/>

		<Root level="INFO">
			<AppenderRef ref="stdout"/>
		</Root>

	</Loggers>
</Configuration>
